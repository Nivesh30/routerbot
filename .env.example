# RouterBot Environment Variables
# Copy this file to .env and fill in your values.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
#   docker compose --profile monitoring up -d  # with Prometheus + Grafana

# ─── Required ──────────────────────────────────────────────
ROUTERBOT_MASTER_KEY=sk-routerbot-CHANGE-THIS
DATABASE_URL=postgresql+asyncpg://routerbot:routerbot@localhost:5432/routerbot
REDIS_URL=redis://localhost:6379/0

# ─── Docker Compose Ports ─────────────────────────────────
ROUTERBOT_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ─── PostgreSQL Credentials ───────────────────────────────
POSTGRES_USER=routerbot
POSTGRES_PASSWORD=routerbot
POSTGRES_DB=routerbot

# ─── Provider API Keys (set the ones you use) ─────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# GEMINI_API_KEY=
# GROQ_API_KEY=
# COHERE_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# PERPLEXITY_API_KEY=

# ─── JWT / Auth ───────────────────────────────────────────
# ROUTERBOT_JWT_SECRET=change-me-in-production

# ─── Optional ─────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# PORT=4000
# HOST=0.0.0.0

# ─── Observability (enable with: docker compose --profile monitoring up) ──
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
