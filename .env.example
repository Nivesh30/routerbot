# RouterBot Environment Variables
# Copy this file to .env and fill in your values.

# ─── Required ──────────────────────────────────────────────
ROUTERBOT_MASTER_KEY=sk-routerbot-CHANGE-THIS
DATABASE_URL=postgresql+asyncpg://routerbot:routerbot@localhost:5432/routerbot
REDIS_URL=redis://localhost:6379/0

# ─── Provider API Keys (set the ones you use) ─────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# GEMINI_API_KEY=
# GROQ_API_KEY=
# COHERE_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# PERPLEXITY_API_KEY=

# ─── Optional ─────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# PORT=4000
# HOST=0.0.0.0
